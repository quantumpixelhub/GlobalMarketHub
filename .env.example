# ============================================================================
# DATABASE (Supabase)
# ============================================================================
DATABASE_URL="postgresql://user:password@db.supabaseapi.com:5432/postgres"

# ============================================================================
# AUTHENTICATION
# ============================================================================
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
JWT_SECRET="generate-with: openssl rand -base64 32"
JWT_EXPIRY=3600
JWT_REFRESH_EXPIRY=2592000

# ============================================================================
# PAYMENT GATEWAYS - UddoktaPay (Primary)
# ============================================================================
UDDOKTAPAY_API_KEY="your_uddoktapay_api_key"
UDDOKTAPAY_API_SECRET="your_uddoktapay_api_secret"
UDDOKTAPAY_API_URL="https://eshopping.paymently.io/api"
UDDOKTAPAY_PAYMENT_URL="https://eshopping.paymently.io/api/checkout"
UDDOKTAPAY_CHECKOUT_URL="https://eshopping.paymently.io/api/checkout"
UDDOKTAPAY_CHECKOUT_V2_URL="https://eshopping.paymently.io/api/checkout-v2"
UDDOKTAPAY_VERIFY_URL="https://eshopping.paymently.io/api/verify-payment"
UDDOKTAPAY_REFUND_URL="https://eshopping.paymently.io/api/refund-payment"
UDDOKTAPAY_MERCHANT_ID="your_merchant_id"

# ============================================================================
# PAYMENT GATEWAYS - Stripe (Cards)
# ============================================================================
STRIPE_SECRET_KEY="sk_live_xxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxx"

# ============================================================================
# PAYMENT GATEWAYS - Mobile Wallets (Optional - Admin Configurable)
# ============================================================================
BKASH_API_KEY="your_bkash_api_key"
BKASH_API_SECRET="your_bkash_api_secret"
BKASH_USERNAME="your_bkash_username"
BKASH_PASSWORD="your_bkash_password"

NAGAD_API_KEY="your_nagad_api_key"
NAGAD_MERCHANT_ID="your_nagad_merchant_id"

ROCKET_API_KEY="your_rocket_api_key"
ROCKET_MERCHANT_ID="your_rocket_merchant_id"

IPAY_API_KEY="your_ipay_api_key"
IPAY_MERCHANT_ID="your_ipay_merchant_id"

# ============================================================================
# EMAIL SERVICE (EmailJS)
# ============================================================================
EMAILJS_SERVICE_ID="service_xxxxx"
EMAILJS_TEMPLATE_ID="template_xxxxx"
EMAILJS_FROM_EMAIL="noreply@globalmarkethub.com"
EMAILJS_PUBLIC_KEY="public_key_xxxxx"
EMAILJS_PRIVATE_KEY="private_key_xxxxx"

# ============================================================================
# EXTERNAL APIs
# ============================================================================
DARAZ_API_KEY="your_daraz_api_key"
DARAZ_API_URL="https://api.daraz.com.bd"

PICKABOO_API_KEY="your_pickaboo_api_key"
PICKABOO_API_URL="https://api.pickaboo.com"

SAJGOJ_API_KEY="your_sajgoj_api_key"
SAJGOJ_API_URL="https://api.sajgoj.com"

# ============================================================================
# FRONTEND URLs (Public - NEXT_PUBLIC_ prefix)
# ============================================================================
NEXT_PUBLIC_API_URL="https://yoursite.vercel.app/api"
NEXT_PUBLIC_SITE_URL="https://yoursite.vercel.app"
NEXT_PUBLIC_STRIPE_PUBLIC_KEY="pk_live_xxxxx"

# ============================================================================
# APPLICATION
# ============================================================================
NODE_ENV="development"
LOG_LEVEL="debug"
PORT=3000

# ============================================================================
# OPTIONAL: Analytics & Monitoring
# ============================================================================
# SENTRY_DSN="https://xxxxx@sentry.io/xxx"
# GOOGLE_ANALYTICS_ID="G-xxxxx"
